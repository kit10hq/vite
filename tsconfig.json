{
	"compilerOptions": {
		"esModuleInterop": true,
		"skipLibCheck": true,
		"target": "es2022",
		"moduleDetection": "force",
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"module": "preserve",
		"noEmit": true,
		"lib": ["es2024"],
		"types": ["*"],
		"declaration": true,
		"isolatedDeclarations": true
	},
	"include": ["src/"],
	"exclude": ["**/*.test.ts"]
}
